# ─────────────────────────────────────────────────────────────────────────────
# Multi-Modal Assistant v2 – Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control (.gitignore already excludes it).
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS Credentials ───────────────────────────────────────────────────────────
# Leave blank when using IAM roles / instance profiles (EC2, ECS, Lambda).
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=multi-modal-assistant-bucket
S3_PRESIGNED_URL_EXPIRY=3600

# ── Amazon Bedrock – Chat ─────────────────────────────────────────────────────
BEDROCK_CHAT_MODEL_ID=amazon.nova-lite-v1:0
BEDROCK_MAX_TOKENS=5000
BEDROCK_TEMPERATURE=0.65
BEDROCK_TOP_P=0.92

# ── Amazon Bedrock – Image ────────────────────────────────────────────────────
BEDROCK_IMAGE_MODEL_ID=amazon.nova-canvas-v1:0

# ── Amazon Polly ──────────────────────────────────────────────────────────────
POLLY_VOICE_ID=Joanna
POLLY_ENGINE=neural
POLLY_OUTPUT_FORMAT=mp3

# ── Amazon Transcribe ─────────────────────────────────────────────────────────
TRANSCRIBE_LANGUAGE_CODE=en-US
TRANSCRIBE_MEDIA_FORMAT=webm
TRANSCRIBE_JOB_POLL_INTERVAL=2.0

# ── Application ───────────────────────────────────────────────────────────────
# Add your deployed frontend URL (e.g. GitHub Pages) to this list.
APP_CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000","https://krishna-2005-debug.github.io"]
APP_LOG_LEVEL=INFO
