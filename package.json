{
  "name": "multi-modal-assistant-root",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,magenta\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "backend\\.venv\\Scripts\\uvicorn.exe app.main:app --reload --host 0.0.0.0 --port 8000 --app-dir backend --env-file backend\\.env",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "setup": "npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
